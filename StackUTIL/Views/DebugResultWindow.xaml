<Window x:Class="DebugInterceptor.Views.DebugResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔍 Отладочные записи" 
        Height="600" Width="900"
        WindowStyle="ToolWindow" Topmost="True"
        ShowActivated="True" ResizeMode="CanResize"
        FocusManager.FocusedElement="{Binding ElementName=RecordsGrid}">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseCommand}"/>
    </Window.InputBindings>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="📋 Записи:" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="10,0,0,0" 
                       Foreground="Gray" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Таблица записей -->
        <DataGrid x:Name="RecordsGrid" Grid.Row="1" 
                  ItemsSource="{Binding Records}"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  SelectionMode="Extended" SelectionUnit="Cell"
                  GridLinesVisibility="Horizontal"
                  PreviewMouseLeftButtonDown="DataGrid_OnPreviewMouseLeftButtonDown"
                  SelectedCellsChanged="DataGrid_OnSelectedCellsChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Row ID" Binding="{Binding RowId}" Width="80"/>
                <DataGridTextColumn Header="Таблица" Binding="{Binding TableName}" Width="*"/>
                <DataGridTextColumn Header="SQL-запрос" Binding="{Binding GeneratedQuery}" Width="2*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель действий -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,10">
            <Button Content="📋 Копировать выбранные" Command="{Binding CopySelectedCommand}" 
                    Margin="0,0,8,0" Width="160"/>
            <Button Content="▶ Выполнить выбранные" Command="{Binding ExecuteSelectedCommand}" 
                    Margin="0,0,8,0" Width="140" 
                    IsEnabled="{Binding IsExecuting, Converter={StaticResource InverseBoolConverter}}"/>
            <Button Content="▶ Выполнить все" Command="{Binding ExecuteAllCommand}" 
                    Width="120"
                    IsEnabled="{Binding IsExecuting, Converter={StaticResource InverseBoolConverter}}"/>
            <Button Content="✖ Закрыть" Command="{Binding CloseCommand}" 
                    Margin="10,0,0,0" Width="100" IsCancel="True"/>
        </StackPanel>

        <!-- 🔹 Результаты выполнения -->
        <TextBlock Grid.Row="3" Text="📊 Результаты выполнения:" 
                   FontWeight="Bold" Margin="0,0,0,5"/>

        <DataGrid Grid.Row="3" ItemsSource="{Binding QueryResults}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  GridLinesVisibility="Horizontal" VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Таблица" Binding="{Binding SourceRecord.TableName}" Width="120"/>
                <DataGridTextColumn Header="Строк" Binding="{Binding RowCount}" Width="60"/>
                <DataGridTextColumn Header="Время (мс)" Binding="{Binding ExecutionTimeMs}" Width="80"/>
                <DataGridTemplateColumn Header="Статус" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="Gray"/>
                                        <Setter Property="Text" Value="⏳"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Success">
                                                <Setter Property="Foreground" Value="Green"/>
                                                <Setter Property="Text" Value="✅"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Error">
                                                <Setter Property="Foreground" Value="Red"/>
                                                <Setter Property="Text" Value="❌"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Результат" Binding="{Binding Rows[0]}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="" Width="30">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="📋" ToolTip="Копировать первую строку"
                                    Command="{Binding DataContext.CopyResultCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Padding="2,0" FontSize="10"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Подсказка -->
        <TextBlock Grid.Row="4" Text="💡 Клик по ячейке — копировать | ▶ — выполнить запрос | 📋 — копировать результат" 
                   Foreground="Gray" FontSize="10" HorizontalAlignment="Right"/>
    </Grid>
</Window>