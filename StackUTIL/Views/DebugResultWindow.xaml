<Window x:Class="DebugInterceptor.Views.DebugResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔍 Отладочные записи" 
        Height="600" Width="900"
        WindowStyle="ToolWindow" Topmost="True"
        ShowActivated="True" ResizeMode="CanResize"
        FocusManager.FocusedElement="{Binding ElementName=RecordsGrid}">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseCommand}"/>
    </Window.InputBindings>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- 1: Таблица записей (больше места) -->
            <RowDefinition Height="Auto"/>
            <!-- 2: Панель действий -->
            <RowDefinition Height="4"/>
            <!-- 3: GridSplitter -->
            <RowDefinition Height="Auto"/>
            <!-- 4: Заголовок результатов -->
            <RowDefinition Height="3*"/>
            <!-- 5: Результаты (фиксированная пропорция) -->
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="📋 Записи:" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="10,0,0,0" 
                       Foreground="Gray" VerticalAlignment="Center"/>
            <!-- 🔹 ComboBox выбора подключения (справа) -->
            <ComboBox ItemsSource="{Binding AvailableConnections}"
              SelectedItem="{Binding SelectedConnection, Mode=TwoWay}"
              Width="220" Margin="20,0,0,0"
              ToolTip="Выберите базу данных для выполнения запросов"
              HorizontalAlignment="Right"
              VerticalContentAlignment="Center">

                    <!-- 🔹 Отображение выбранного элемента (как в выпадающем списке) -->
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text=" • " Foreground="Gray" Margin="4,0"/>
                                <TextBlock Text="{Binding DatabaseType}" Foreground="DarkBlue" FontSize="10"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <!-- Таблица записей -->
        <DataGrid x:Name="RecordsGrid" Grid.Row="1" 
                  ItemsSource="{Binding Records}"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  SelectionMode="Extended" SelectionUnit="Cell"
                  GridLinesVisibility="Horizontal"
                  PreviewMouseLeftButtonDown="DataGrid_OnPreviewMouseLeftButtonDown"
                  SelectedCellsChanged="DataGrid_OnSelectedCellsChanged">
            
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="Row ID" Binding="{Binding RowId}" Width="80"/>
                <DataGridTextColumn Header="Таблица" Binding="{Binding TableName}" Width="*"/>
                <DataGridTextColumn Header="SQL-запрос" Binding="{Binding GeneratedQuery}" Width="2*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>


        <!-- Панель действий -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,10">
            <!-- Кнопка копирования -->
            <Button Content="📋 Копировать выбранные" 
            Command="{Binding CopySelectedCommand}" 
            Margin="0,0,8,0" Width="160">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExecuting}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- 🔹 Кнопка выполнения запроса - ПРОСТАЯ ВЕРСИЯ -->
            <Button Content="▶ Выполнить запрос" 
            Command="{Binding ExecuteQueryCommand}"
            CommandParameter="{Binding SelectedRecord}"
            Width="140"
            ToolTip="Выберите строку для выполнения">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExecuting}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="ToolTip" Value="Выполняется другой запрос..."/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            
            <Button Content="🗑 Очистить результаты" 
                Command="{Binding ClearResultsCommand}"
                Width="140" Margin="8,0,0,0"/>


            <!-- 🔹 Статус подключения -->
            <TextBlock Text="{Binding ConnectionStatus}" 
               Margin="16,0,0,0" VerticalAlignment="Center" 
               Foreground="Gray" FontSize="11" FontWeight="Normal"/>

            <!-- Индикатор выполнения -->
            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Foreground="Gray">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Setter Property="Text" Value=""/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExecuting}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Setter Property="Text" Value="⏳ Выполнение..."/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            
        </StackPanel>

        <!-- Разделитель -->
        <GridSplitter Grid.Row="3" Height="4" HorizontalAlignment="Stretch" 
              Background="#DDD" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"/>

        <!-- Заголовок результатов -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,8,0,4">
            <TextBlock Text="📊 Результаты:" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="10,0,0,0" 
               Foreground="Gray" VerticalAlignment="Center" FontSize="11"/>
        </StackPanel>

        <!-- Область результатов со скроллом -->
        <ScrollViewer Grid.Row="5" 
              VerticalScrollBarVisibility="Auto" 
              HorizontalScrollBarVisibility="Auto"
              Background="#FAFAFA">

            <ItemsControl ItemsSource="{Binding ExecutionResults}"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">

                <!-- 🔹 Панель с отступами между элементами -->
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Margin="0,0,8,0"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- 🔹 GroupBox с ограничением высоты -->
                        <GroupBox Header="{Binding DisplayName, Mode=OneWay}" 
                          Margin="0,4,0,12" Padding="8"
                          BorderBrush="#CCC" BorderThickness="1"
                          MaxHeight="500">
                            <!-- 🔹 Ограничение высоты одного результата -->

                            <StackPanel>
                                <!-- SQL-запрос (сворачиваемый) -->
                                <Expander Header="📜 Запрос" IsExpanded="False" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding Source.ExecutedQuery, Mode=OneWay}" 
                                       FontFamily="Consolas" FontSize="10" 
                                       TextWrapping="Wrap" Background="#F0F0F0" 
                                       Padding="6" Margin="0,4,0,0"
                                       MaxHeight="100"/>
                                    <!-- 🔹 Ограничение высоты запроса -->
                                </Expander>

                                <!-- Таблица данных с собственным скроллом -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                      HorizontalScrollBarVisibility="Auto"
                                      MaxHeight="300">
                                    <!-- 🔹 Ограничение высоты таблицы -->
                                    <DataGrid ItemsSource="{Binding Data, Mode=OneWay}" 
                                      AutoGenerateColumns="True"
                                      CanUserAddRows="False" IsReadOnly="True"
                                      GridLinesVisibility="All"
                                      HeadersVisibility="Column"
                                      RowHeight="22" FontSize="11"
                                      MinHeight="40"/>
                                </ScrollViewer>

                                <!-- Статус -->
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock FontWeight="Bold">
                                <Run Text="Статус:"/>
                                <Run Text="{Binding Source.Status, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Margin="16,0,0,0" FontWeight="Bold">
                                <Run Text="Строк:"/>
                                <Run Text="{Binding Source.RowCount, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Margin="16,0,0,0">
                                <Run Text="⏱"/>
                                <Run Text="{Binding ExecutionTimeDisplay, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Ошибка -->
                                <TextBlock Text="{Binding Source.Error, Mode=OneWay}" 
                                   Foreground="DarkRed" 
                                   TextWrapping="Wrap"
                                   Background="#FFF0F0" 
                                   Padding="6" 
                                   Margin="0,6,0,0"/>
                            </StackPanel>

                        </GroupBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Подсказка -->
        <TextBlock Grid.Row="4" Text="💡 Клик по ячейке — копировать" 
                   Foreground="Gray" FontSize="10" HorizontalAlignment="Right"/>
    </Grid>
</Window>