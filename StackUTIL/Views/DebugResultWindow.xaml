<Window x:Class="DebugInterceptor.Views.DebugResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔍 Отладочные записи" 
        Height="500" Width="800"
        WindowStyle="ToolWindow" Topmost="True"
        ShowActivated="True"   
        ResizeMode="CanResize"
        FocusManager.FocusedElement="{Binding ElementName=RecordsGrid}">
    
    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseCommand}"/>
    </Window.InputBindings>

    <Grid Margin="10" x:Name="RecordsGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="📋 Найдено записей:" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="10,0,0,0" 
                       Foreground="Gray" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Таблица записей -->
        <DataGrid Grid.Row="1" 
          ItemsSource="{Binding Records}"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="True"
          SelectionMode="Extended"
          SelectionUnit="Cell"
          GridLinesVisibility="Horizontal"
          PreviewMouseLeftButtonDown="DataGrid_OnPreviewMouseLeftButtonDown"
          SelectedCellsChanged="DataGrid_OnSelectedCellsChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Row ID" Binding="{Binding RowId}" Width="80"/>
                <DataGridTextColumn Header="Таблица" Binding="{Binding TableName}" Width="*"/>
                <DataGridTextColumn Header="SQL-запрос" Binding="{Binding GeneratedQuery}" Width="2*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель действий -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,10">
            <Button Content="📋 Копировать выбранные" 
                    Command="{Binding CopySelectedCommand}"
                    Margin="0,0,8,0" Width="160"
                    ToolTip="Ctrl: добавить к выделению, Shift: диапазон"/>
            <Button Content="✖ Закрыть" 
                    Command="{Binding CloseCommand}"
                    IsCancel="True" Width="100"/>
        </StackPanel>

        <!-- Подсказка -->
        <TextBlock Grid.Row="3" Text="💡 Клик по ячейке — копировать значение | Ctrl/Shift — мультиселект" 
                   Foreground="Gray" FontSize="10" HorizontalAlignment="Right"/>
    </Grid>
</Window>